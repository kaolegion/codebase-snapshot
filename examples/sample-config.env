# codebase-snapshot sample configuration

# Target repository to snapshot
TARGET_ROOT="/path/to/project"

# Human-readable snapshot label
SNAPSHOT_LABEL="initial"

# Optional output root
OUTPUT_ROOT="./snapshots"

# Optional exclusions
EXCLUDE_PATTERNS=".git node_modules dist build .venv __pycache__ logs snapshots"

# Logging level
LOG_LEVEL="INFO"
