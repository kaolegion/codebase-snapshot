#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VERSION_FILE="$ROOT_DIR/VERSION"

usage() {
    cat <<'USAGE'
codebase-snapshot

Usage:
  bin/snapshot --target <path> --label <label>
  bin/snapshot --help
  bin/snapshot --version

Options:
  --target   Path to the repository to snapshot
  --label    Human-readable snapshot label
  --help     Show this help message
  --version  Show tool version
USAGE
}

read_version() {
    if [[ -f "$VERSION_FILE" ]]; then
        cat "$VERSION_FILE"
    else
        echo "0.0.0"
    fi
}

TARGET=""
LABEL=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help)
            usage
            exit 0
            ;;
        --version)
            read_version
            exit 0
            ;;
        --target)
            shift
            [[ $# -gt 0 ]] || {
                echo "[ERROR] Missing value for --target"
                exit 2
            }
            TARGET="$1"
            ;;
        --label)
            shift
            [[ $# -gt 0 ]] || {
                echo "[ERROR] Missing value for --label"
                exit 2
            }
            LABEL="$1"
            ;;
        *)
            echo "[ERROR] Unknown argument: $1"
            usage
            exit 2
            ;;
    esac
    shift
done

[[ -n "$TARGET" ]] || {
    echo "[ERROR] --target is required"
    usage
    exit 2
}

[[ -n "$LABEL" ]] || {
    echo "[ERROR] --label is required"
    usage
    exit 2
}

[[ -d "$TARGET" ]] || {
    echo "[ERROR] Target directory not found: $TARGET"
    exit 1
}

VERSION="$(read_version)"

echo "[INFO] codebase-snapshot v$VERSION"
echo "[INFO] Target: $TARGET"
echo "[INFO] Label: $LABEL"
echo "[INFO] Snapshot CLI initialized"
