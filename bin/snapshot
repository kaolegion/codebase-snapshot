#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VERSION_FILE="$ROOT_DIR/VERSION"

source "$ROOT_DIR/core/naming.sh"
source "$ROOT_DIR/core/utils.sh"
source "$ROOT_DIR/core/scanner.sh"
source "$ROOT_DIR/core/indexer.sh"
source "$ROOT_DIR/core/architecture.sh"
source "$ROOT_DIR/core/documentation.sh"
source "$ROOT_DIR/core/languages.sh"
source "$ROOT_DIR/core/dependencies.sh"
source "$ROOT_DIR/core/graph.sh"
source "$ROOT_DIR/core/semantics.sh"
source "$ROOT_DIR/core/entrypoints.sh"
source "$ROOT_DIR/core/purpose.sh"
source "$ROOT_DIR/core/structure.sh"
source "$ROOT_DIR/core/explanation.sh"
source "$ROOT_DIR/core/repository_explain.sh"
source "$ROOT_DIR/core/dna.sh"
source "$ROOT_DIR/core/diff.sh"

usage() {
    cat <<'USAGE'
codebase-snapshot

Usage:
  bin/snapshot --target <path> --label <label>
  bin/snapshot diff <snapshotA> <snapshotB>
  bin/snapshot --help
  bin/snapshot --version
USAGE
}

read_version() {
    [[ -f "$VERSION_FILE" ]] && cat "$VERSION_FILE" || echo "0.0.0"
}

append_section_file() {
    local outfile="$1"
    local filepath="$2"

    {
        printf "# FILE: %s\n\n" "$filepath"
        printf '```text\n'
        cat "$filepath"
        printf '\n```\n\n'
    } >> "$outfile"
}

run_snapshot_generation() {
    local target=""
    local label=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --target)
                shift
                [[ $# -gt 0 ]] || { echo "[ERROR] Missing value for --target"; exit 2; }
                target="$1"
                ;;
            --label)
                shift
                [[ $# -gt 0 ]] || { echo "[ERROR] Missing value for --label"; exit 2; }
                label="$1"
                ;;
            *)
                echo "[ERROR] Unknown argument: $1"
                exit 2
                ;;
        esac
        shift
    done

    [[ -n "$target" ]] || { echo "[ERROR] --target required"; exit 2; }
    [[ -n "$label" ]] || { echo "[ERROR] --label required"; exit 2; }

    require_dir "$target"

    local version
    local date
    local normalized_label
    local seq
    local snapshot_dir
    local codebase_dir
    local file_count
    local cli_export
    local core_export
    local tests_export
    local docs_export

    version="$(read_version)"
    date="$(current_date)"
    normalized_label="$(normalize_label "$label")"
    seq="01"

    snapshot_dir="$ROOT_DIR/snapshots/$date/$version/${seq}_${normalized_label}"
    codebase_dir="$snapshot_dir/CODEBASE"

    mkdir -p "$snapshot_dir"
    mkdir -p "$codebase_dir"

    scan_files "$target" > "$snapshot_dir/PROJECT_TREE.txt"
    generate_index "$target" > "$snapshot_dir/INDEX.tsv"
    generate_dependencies "$target" > "$snapshot_dir/DEPENDENCIES.tsv"
    generate_graph "$target" > "$snapshot_dir/GRAPH.tsv"
    generate_semantics "$target" > "$snapshot_dir/SEMANTICS.tsv"
    generate_entrypoints "$target" > "$snapshot_dir/ENTRYPOINTS.tsv"
    generate_modules "$target" > "$snapshot_dir/MODULES.tsv"
    generate_subsystems "$target" > "$snapshot_dir/SUBSYSTEMS.tsv"

    render_architecture "$target" > "$snapshot_dir/ARCHITECTURE.md"
    render_documentation_index "$target" > "$snapshot_dir/DOCUMENTATION.md"
    render_languages "$target" > "$snapshot_dir/LANGUAGES.md"
    render_components_summary "$target" > "$snapshot_dir/COMPONENTS.md"
    detect_repository_purpose "$target" > "$snapshot_dir/PURPOSE.md"
    render_system_flow "$target" > "$snapshot_dir/SYSTEM_FLOW.md"
    render_repository_explain "$target" > "$snapshot_dir/REPOSITORY_EXPLAIN.md"
    render_repository_dna "$target" > "$snapshot_dir/REPOSITORY_DNA.md"

    file_count="$(scan_files "$target" | wc -l | tr -d ' ')"

    cat > "$snapshot_dir/MANIFEST.md" <<MANIFEST
# Snapshot Manifest

Tool version: $version
Generated at: $date

Target repository:
$target

Snapshot label:
$label

Normalized label:
$normalized_label

Included files:
$file_count
MANIFEST

    cat > "$snapshot_dir/AI_INGESTION_GUIDE.md" <<GUIDE
# AI Ingestion Guide

This snapshot was generated by **codebase-snapshot**.

Recommended reading order:

1. MANIFEST.md
2. REPOSITORY_EXPLAIN.md
3. PURPOSE.md
4. SYSTEM_FLOW.md
5. COMPONENTS.md
6. ARCHITECTURE.md
7. LANGUAGES.md
8. DOCUMENTATION.md
9. ENTRYPOINTS.tsv
10. MODULES.tsv
11. SUBSYSTEMS.tsv
12. SEMANTICS.tsv
13. GRAPH.tsv
14. DEPENDENCIES.tsv
15. PROJECT_TREE.txt
16. INDEX.tsv
17. CODEBASE/01_cli.md
18. CODEBASE/02_core.md
19. CODEBASE/03_tests.md
20. CODEBASE/04_docs.md

Important notes:

- The snapshot is deterministic.
- Exclusion rules are applied during scanning.
- REPOSITORY_EXPLAIN.md provides the final high-level repository synthesis.
- PURPOSE.md summarizes the probable repository role using deterministic signals.
- SYSTEM_FLOW.md explains how the repository operates internally.
- COMPONENTS.md summarizes repository-level semantic components.
- ENTRYPOINTS.tsv detects deterministic repository execution entrypoints.
- MODULES.tsv maps the repository to main architectural modules.
- SUBSYSTEMS.tsv maps stable functional subsystems inside repository modules.
- SEMANTICS.tsv maps files to repository components and detection rules.
- LANGUAGES.md summarizes detected file types.
- DOCUMENTATION.md lists project markdown documentation.
- GRAPH.tsv provides structural repository relationships.
- DEPENDENCIES.tsv extracts dependency signals from source files.
- ARCHITECTURE.md summarizes repository structure.
- CODEBASE/ groups source files for ingestion.
GUIDE

    cli_export="$codebase_dir/01_cli.md"
    core_export="$codebase_dir/02_core.md"
    tests_export="$codebase_dir/03_tests.md"
    docs_export="$codebase_dir/04_docs.md"

    printf "# CLI EXPORT\n\n" > "$cli_export"
    printf "# CORE EXPORT\n\n" > "$core_export"
    printf "# TESTS EXPORT\n\n" > "$tests_export"
    printf "# DOCS EXPORT\n\n" > "$docs_export"

    scan_files "$target" | while read -r file; do
        case "$file" in
            */bin/*|bin/*)
                append_section_file "$cli_export" "$file"
                ;;
            */core/*|core/*)
                append_section_file "$core_export" "$file"
                ;;
            */tests/*|tests/*)
                append_section_file "$tests_export" "$file"
                ;;
            */doc/*|doc/*|*.md)
                append_section_file "$docs_export" "$file"
                ;;
        esac
    done

    cat > "$snapshot_dir/LOG.txt" <<LOG
[INFO] codebase-snapshot v$version
[INFO] Target: $target
[INFO] Label: $label
[INFO] Snapshot directory: $snapshot_dir
[INFO] CODEBASE export enabled
[INFO] Exclusion rules enabled
[INFO] Architecture summary generated
[INFO] Documentation index generated
[INFO] Language summary generated
[INFO] Dependency mapping generated
[INFO] Graph mapping generated
[INFO] Semantic mapping generated
[INFO] Entrypoint mapping generated
[INFO] Module mapping generated
[INFO] Subsystem mapping generated
[INFO] Components summary generated
[INFO] Purpose summary generated
[INFO] System flow summary generated
[INFO] Repository explain summary generated
[INFO] Repository DNA summary generated
LOG

    cat > "$snapshot_dir/SNAPSHOT_META.json" <<META
{
  "snapshot_version": "1",
  "tool_version": "$version",
  "generated_at": "$date",
  "target_root": "$target",
  "label": "$label",
  "normalized_label": "$normalized_label",
  "sequence": "$seq",
  "file_count": $file_count
}
META

    echo "[INFO] Snapshot generated: $snapshot_dir"
}

run_snapshot_diff() {
    local snapshot_a="${1:-}"
    local snapshot_b="${2:-}"
    local diff_dir

    [[ -n "$snapshot_a" ]] || {
        echo "[ERROR] Usage: bin/snapshot diff <snapshotA> <snapshotB>" >&2
        exit 2
    }

    [[ -n "$snapshot_b" ]] || {
        echo "[ERROR] Usage: bin/snapshot diff <snapshotA> <snapshotB>" >&2
        exit 2
    }

    require_snapshot_for_diff "$snapshot_a"
    require_snapshot_for_diff "$snapshot_b"

    diff_dir="$(snapshot_diff_output_dir "$snapshot_a" "$snapshot_b")"

    rm -rf "$diff_dir"
    mkdir -p "$diff_dir"

    generate_snapshot_diff "$snapshot_a" "$snapshot_b" > "$diff_dir/DIFF.tsv"
    render_snapshot_diff "$snapshot_a" "$snapshot_b" "$diff_dir/DIFF.tsv" > "$diff_dir/SNAPSHOT_DIFF.md"

    echo "[INFO] Snapshot diff generated: $diff_dir"
}

main() {
    [[ $# -gt 0 ]] || {
        usage
        exit 2
    }

    case "${1:-}" in
        --help)
            usage
            exit 0
            ;;
        --version)
            read_version
            exit 0
            ;;
        diff)
            shift
            run_snapshot_diff "$@"
            ;;
        *)
            run_snapshot_generation "$@"
            ;;
    esac
}

main "$@"
